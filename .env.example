# =============================================================================
# The 19th Hole — Environment Configuration
# =============================================================================
# Copy this file to .env.local for local development.

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# Found in Clerk dashboard → JWT Templates → Convex template → Issuer
CLERK_JWT_ISSUER_DOMAIN=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create a recurring monthly product in Stripe dashboard for the Club Plan
STRIPE_PRICE_CLUB_PLAN=

# Corti AI
CORTI_BASE_URL=https://api.eu.corti.app
CORTI_CLIENT_ID=
CORTI_CLIENT_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
