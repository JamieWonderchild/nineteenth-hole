# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env.local for local development.
# Never put real secrets in this file — it is committed to git.
#
# Convex deployment: kindly-opossum-400 (eu-west-1)
# =============================================================================

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Convex Database
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Corti (speech-to-text, fact extraction, medical coding)
CORTI_CLIENT_ID=
CORTI_CLIENT_SECRET=
CORTI_TENANT=
CORTI_ENV=eu

# Stripe (billing)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_PRACTICE=
STRIPE_PRICE_MULTI=
STRIPE_PRICE_EXTRA_SEAT_PRACTICE=
STRIPE_PRICE_EXTRA_SEAT_MULTI=

# Twilio (optional — SMS delivery for Patient Companion links)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Epic FHIR (optional — EHR integration via SMART on FHIR)
EPIC_CLIENT_ID=
EPIC_FHIR_BASE_URL=
EPIC_REDIRECT_URI=

# Superadmin (comma-separated Clerk user emails)
NEXT_PUBLIC_SUPERADMIN_EMAILS=
