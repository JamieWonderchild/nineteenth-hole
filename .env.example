# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env.local for local development
#
# TWO ENVIRONMENTS:
# - Dev: localhost:3000 → dev Convex + dev Clerk + dev Corti
# - Prod: vetrinair.com → prod Convex + prod Clerk + prod Corti
# =============================================================================

# Clerk Authentication
# Dev: pk_test_... / sk_test_... (works on localhost)
# Prod: pk_live_... / sk_live_... (only works on vetrinair.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Convex Database
# Dev: dev:striped-raccoon-786
# Prod: prod:charming-blackbird-181
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Corti (speech-to-text, fact extraction, agentic API)
CORTI_CLIENT_ID=
CORTI_CLIENT_SECRET=
CORTI_TENANT=
CORTI_ENV=eu  # or us

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_PRACTICE=
STRIPE_PRICE_MULTI=
STRIPE_PRICE_EXTRA_SEAT_PRACTICE=
STRIPE_PRICE_EXTRA_SEAT_MULTI=

# Twilio (SMS delivery for Patient Companion links)
# Sign up at twilio.com — get a Twilio phone number for the From field
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=   # E.164 format, e.g. +15551234567

# Epic FHIR (Phase 8 — register at fhir.epic.com, use open.epic.com for sandbox)
EPIC_CLIENT_ID=       # From Epic App Orchard (sandbox: non-production client ID)
EPIC_FHIR_BASE_URL=   # e.g. https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_REDIRECT_URI=    # e.g. https://yourdomain.com/fhir-launch/callback

# Superadmin (comma-separated emails)
NEXT_PUBLIC_SUPERADMIN_EMAILS=
