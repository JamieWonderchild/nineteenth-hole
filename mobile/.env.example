# =============================================================================
# The 19th Hole — Mobile App Environment
# =============================================================================
# Copy this file to .env.local for local development.
# Values must match the root project's .env.local.

# Clerk — use the same publishable key as the web app
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Convex — use the same deployment URL as the web app
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
